<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="Electron">
  <diagram id="search-lifecycle" name="搜索生命周期">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="900" background="#ffffff">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- 标题 -->
        <mxCell id="t0" value="搜索请求生命周期" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=20;fontFamily=Helvetica;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="400" height="28" as="geometry"/>
        </mxCell>
        <mxCell id="t0s" value="用户输入 → bge-m3 嵌入 → 余弦相似度 → dynamic_cut → rule_filter → JSON 日志 → 返回结果" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;fontFamily=Menlo;fontColor=#888888;" vertex="1" parent="1">
          <mxGeometry x="40" y="46" width="800" height="18" as="geometry"/>
        </mxCell>

        <!-- ===== 阶段 1：请求 ===== -->
        <mxCell id="ph1" value="阶段 1：请求入口" style="swimlane;html=1;startSize=20;horizontal=1;fillColor=#e3f2fd;strokeColor=#1976d2;swimlaneFillColor=#e3f2fd;fontSize=11;fontFamily=Helvetica;fontColor=#1565c0;" vertex="1" parent="1">
          <mxGeometry x="30" y="80" width="1140" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="browser" value="&lt;b&gt;🌐 app.html&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:10px;color:#555;&quot;&gt;浏览器 GUI&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#bbdefb;strokeColor=#1976d2;fontSize=11;fontFamily=Helvetica;fontColor=#222222;" vertex="1" parent="1">
          <mxGeometry x="60" y="108" width="100" height="42" as="geometry"/>
        </mxCell>

        <mxCell id="arrow1" value="POST /api/search" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=none;fontSize=10;fontFamily=Menlo;fontColor=#1976d2;align=center;" vertex="1" parent="1">
          <mxGeometry x="165" y="115" width="120" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="sv" value="&lt;b&gt;📡 serve.py&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:10px;color:#555;&quot;&gt;do_POST /api/search&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#90caf9;strokeColor=#1976d2;fontSize=11;fontFamily=Helvetica;fontColor=#222222;" vertex="1" parent="1">
          <mxGeometry x="290" y="108" width="120" height="42" as="geometry"/>
        </mxCell>

        <mxCell id="c1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#1976d2;strokeWidth=2;" edge="1" parent="1" source="browser" target="sv">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ===== 阶段 2：向量检索 ===== -->
        <mxCell id="ph2" value="阶段 2：向量检索（≈ 4.5s）" style="swimlane;html=1;startSize=20;horizontal=1;fillColor=#fce4ec;strokeColor=#c2185b;swimlaneFillColor=#fce4ec;fontSize=11;fontFamily=Helvetica;fontColor=#a31545;" vertex="1" parent="1">
          <mxGeometry x="30" y="180" width="1140" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="embed" value="&lt;b&gt;bge-m3 嵌入&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:10px;&quot;&gt;embed_query(&quot;平淡一点&quot;)&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#bbb;&quot;&gt;→ 1024 维向量&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ad1457;strokeColor=#880e4f;fontSize=11;fontFamily=Helvetica;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="60" y="210" width="150" height="48" as="geometry"/>
        </mxCell>

        <mxCell id="cosine" value="&lt;b&gt;余弦相似度&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:10px;&quot;&gt;np.dot(v_norm, q_norm)&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#bbb;&quot;&gt;→ 152 个 0~1 分数&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d81b60;strokeColor=#880e4f;fontSize=11;fontFamily=Helvetica;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="270" y="210" width="150" height="48" as="geometry"/>
        </mxCell>

        <mxCell id="vec" value="&lt;b&gt;vectors.npy&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:10px;&quot;&gt;(152, 1024) float32&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#bbb;&quot;&gt;.lut_vectors/&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#6a1b9a;strokeColor=#4a148c;fontSize=11;fontFamily=Helvetica;fontColor=#ffffff;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="210" width="120" height="48" as="geometry"/>
        </mxCell>

        <mxCell id="c2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#c2185b;strokeWidth=1.5;" edge="1" parent="1" source="embed" target="cosine">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="c3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#c2185b;strokeWidth=1.5;" edge="1" parent="1" source="cosine" target="vec">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="ollama" value="⏳ Ollama API&#10;localhost:11434" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;fillColor=#ffcc02;strokeColor=#f57f17;fontSize=9;fontFamily=Helvetica;fontColor=#333;" vertex="1" parent="1">
          <mxGeometry x="85" y="262" width="90" height="28" as="geometry"/>
        </mxCell>

        <mxCell id="c2s" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0.15;entryY=0;strokeColor=#f57f17;strokeWidth=1;dashed=1;" edge="1" parent="1" source="embed" target="ollama">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ===== 阶段 3：后处理 ===== -->
        <mxCell id="ph3" value="阶段 3：后处理（&lt; 1ms）" style="swimlane;html=1;startSize=20;horizontal=1;fillColor=#e8f5e9;strokeColor=#388e3c;swimlaneFillColor=#e8f5e9;fontSize=11;fontFamily=Helvetica;fontColor=#27632a;" vertex="1" parent="1">
          <mxGeometry x="30" y="320" width="1140" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="dcut" value="&lt;b&gt;dynamic_cut&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:10px;&quot;&gt;min_score=0.4 | max=6&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#bbb;&quot;&gt;陡降 &gt;0.15 截断&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2e7d32;strokeColor=#1b5e20;fontSize=11;fontFamily=Helvetica;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="60" y="350" width="140" height="46" as="geometry"/>
        </mxCell>

        <mxCell id="rf" value="&lt;b&gt;rule_filter&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:10px;&quot;&gt;6 意图方向排除&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#bbb;&quot;&gt;低/高对比 · 低/高饱和 · 暖/冷&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#388e3c;strokeColor=#1b5e20;fontSize=11;fontFamily=Helvetica;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="260" y="350" width="170" height="46" as="geometry"/>
        </mxCell>

        <mxCell id="preset" value="&lt;b&gt;Preset 元数据&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:10px;&quot;&gt;contrast / saturation / tone&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#bbb;&quot;&gt;parser.py 关键词引导&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#6a1b9a;strokeColor=#4a148c;fontSize=10;fontFamily=Helvetica;fontColor=#ffffff;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="490" y="350" width="150" height="46" as="geometry"/>
        </mxCell>

        <mxCell id="c4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#388e3c;strokeWidth=1.5;" edge="1" parent="1" source="dcut" target="rf">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="c5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#6a1b9a;strokeWidth=1;dashed=1;" edge="1" parent="1" source="rf" target="preset">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- 连接 2→3 -->
        <mxCell id="c6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;entryX=0;entryY=0;strokeColor=#c2185b;strokeWidth=1.5;" edge="1" parent="1" source="cosine" target="dcut">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ===== 阶段 4：日志 + 返回 ===== -->
        <mxCell id="ph4" value="阶段 4：日志 + 响应" style="swimlane;html=1;startSize=20;horizontal=1;fillColor=#fff3e0;strokeColor=#ef6c00;swimlaneFillColor=#fff3e0;fontSize=11;fontFamily=Helvetica;fontColor=#bf360c;" vertex="1" parent="1">
          <mxGeometry x="30" y="460" width="1140" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="lj" value="&lt;b&gt;log_search_json&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:10px;&quot;&gt;data/search_log/*.json&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#bbb;&quot;&gt;query + vector + results + click&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e65100;strokeColor=#bf360c;fontSize=11;fontFamily=Helvetica;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="60" y="490" width="160" height="46" as="geometry"/>
        </mxCell>

        <mxCell id="resp" value="&lt;b&gt;返回前端&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:10px;&quot;&gt;{ results, count, ms, search_id }&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;font-size:9px;color:#bbb;&quot;&gt;淡雅warm 0.532 / WARM暖调 0.529 / ...&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#333333;strokeColor=#111111;fontSize=11;fontFamily=Menlo;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="280" y="490" width="240" height="46" as="geometry"/>
        </mxCell>

        <mxCell id="c7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#ef6c00;strokeWidth=1.5;" edge="1" parent="1" source="lj" target="resp">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ===== 底部：链路 + 参数 ===== -->
        <mxCell id="sum" value="调用链路" style="swimlane;html=1;startSize=20;horizontal=1;fillColor=#f5f5f5;strokeColor=#cccccc;swimlaneFillColor=#f5f5f5;fontSize=11;fontFamily=Helvetica;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="30" y="600" width="1140" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="chain" value="app.html → POST → serve.py → embed_query(bge-m3) → np.dot(cosine) → dynamic_cut → rule_filter → log_search_json → 返回 JSON" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;fontFamily=Menlo;fontColor=#444444;" vertex="1" parent="1">
          <mxGeometry x="60" y="625" width="1080" height="18" as="geometry"/>
        </mxCell>

        <mxCell id="param" value="关键参数：batch_size=1 | min_score=0.4 | drop_threshold=0.15 | max_count=6 | CONCURRENCY=3 | 耗时占比：bge-m3 嵌入 ≈ 98%（4.5s），后处理 + 日志 ≈ 2%（&lt; 5ms）" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=10;fontFamily=Menlo;fontColor=#888888;" vertex="1" parent="1">
          <mxGeometry x="60" y="648" width="1080" height="16" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
